rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Role + Email Based Dual-Verification (Security Core)
    function isAdmin() {
      let masterEmails = [
        'admin@blueteeth.in', 
        'nitinchauhan378@gmail.com', 
        'niteen02@gmail.com', 
        'niteen02', 
        'support@blueteeth.in', 
        'master_core_01@blueteeth.in', 
        'backup_core_02@blueteeth.in'
      ];
      return isSignedIn() && 
             (request.auth.token.email.lower() in masterEmails || 
              (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    // 1. Users Collection (Secure Cloud Nodes)
    match /users/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // 1b. Legacy Doctors Collection
    match /doctors/{docId} {
      allow read, write: if isAdmin();
    }

    // 2. Cases Collection (Hardened Registry)
    match /cases/{caseId} {
      allow read: if isSignedIn() && (
        resource.data.doctorUid == request.auth.uid || 
        resource.data.clinicianId == request.auth.uid || 
        isAdmin()
      );
      
      // Prevent users from creating cases with pre-approved points, fake UIDs, or self-assigned clinician status
      allow create: if isSignedIn() && 
        request.resource.data.doctorUid == request.auth.uid &&
        request.resource.data.status == 'Pending' &&
        (request.resource.data.points == 0 || !('points' in request.resource.data)) &&
        !('clinicianId' in request.resource.data) &&
        !('clinicianFee' in request.resource.data);

      allow update: if isAdmin() || (
        isSignedIn() && 
        resource.data.clinicianId == request.auth.uid && 
        request.resource.data.doctorUid == resource.data.doctorUid &&
        (request.resource.data.status == 'In Progress' || request.resource.data.status == 'Submitted')
      );
      allow delete: if isAdmin();
    }
    
    // 3. Redemptions / Withdrawals Collection (Financial Fortress)
    function hasSufficientBalance(amount) {
      return amount <= get(/databases/$(database)/documents/users/$(request.auth.uid)).data.walletBalance;
    }

    match /withdrawals/{id} {
      allow read: if isSignedIn() && (resource.data.doctorUid == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && 
        request.resource.data.doctorUid == request.auth.uid &&
        request.resource.data.status == 'Pending' &&
        hasSufficientBalance(request.resource.data.amount);
      allow update: if isAdmin();
      allow delete: if false;
    }
    
    match /redemptions/{id} {
      allow read: if isSignedIn() && (resource.data.doctorUid == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && 
        request.resource.data.doctorUid == request.auth.uid &&
        request.resource.data.status == 'Pending' &&
        hasSufficientBalance(request.resource.data.amount);
      allow update: if isAdmin();
      allow delete: if false;
    }

    // 4. Global Settings (Exchange Rates, etc.)
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 5. Notifications Collection
    match /notifications/{notifId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.userId == 'admin');
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // Global Deny catch-all
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
