rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core Verification Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // 1. Users Collection (Secure Cloud Nodes)
    match /users/{userId} {
      // Users can only read their own profile; Admins can read all profiles
      allow read: if isOwner(userId) || isAdmin();
      
      // [SECURITY FIX]: Prevent self-promotion to admin or balance tampering
      allow create: if isSignedIn() && request.auth.uid == userId && 
                    request.resource.data.role in ['doctor', 'associate', 'clinician', 'specialist'] &&
                    (request.resource.data.walletBalance == 0 || !('walletBalance' in request.resource.data)) &&
                    (request.resource.data.totalPoints == 0 || !('totalPoints' in request.resource.data));
      
      allow update: if isAdmin() || (
        isOwner(userId) && 
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['role', 'walletBalance', 'totalPoints', 'points', 'isVerified', 'pending', 'email'])
      );

      allow delete: if isAdmin();
    }

    // 1b. Legacy Doctors Collection
    match /doctors/{docId} {
      allow read, write: if isAdmin();
    }

    // 2. Cases Collection (Hardened Registry)
    match /cases/{caseId} {
      allow read: if isSignedIn() && (
        resource.data.doctorUid == request.auth.uid || 
        resource.data.clinicianId == request.auth.uid || 
        isAdmin()
      );
      
      // Prevent users from creating cases with pre-approved points, fake UIDs, or self-assigned clinician status
      allow create: if isSignedIn() && 
        request.resource.data.doctorUid == request.auth.uid &&
        request.resource.data.status == 'Pending' &&
        (request.resource.data.points == 0 || !('points' in request.resource.data)) &&
        !('clinicianId' in request.resource.data) &&
        !('clinicianFee' in request.resource.data);

      allow update: if isAdmin() || (
        isSignedIn() && 
        resource.data.clinicianId == request.auth.uid && 
        request.resource.data.doctorUid == resource.data.doctorUid &&
        (request.resource.data.status == 'In Progress' || request.resource.data.status == 'Submitted')
      );
      allow delete: if isAdmin();
    }
    
    // 3. Redemptions / Withdrawals Collection (Financial Fortress)
    function hasSufficientBalance(amount) {
      return amount <= get(/databases/$(database)/documents/users/$(request.auth.uid)).data.walletBalance;
    }

    match /withdrawals/{id} {
      allow read: if isOwner(resource.data.doctorUid) || isAdmin();
      allow create: if isOwner(request.resource.data.doctorUid) &&
        request.resource.data.status == 'Pending' &&
        hasSufficientBalance(request.resource.data.amount);
      allow update: if isAdmin();
      allow delete: if false;
    }
    
    match /redemptions/{id} {
      allow read: if isOwner(resource.data.doctorUid) || isAdmin();
      allow create: if isOwner(request.resource.data.doctorUid) &&
        request.resource.data.status == 'Pending' &&
        hasSufficientBalance(request.resource.data.amount);
      allow update: if isAdmin();
      allow delete: if false;
    }

    // 4. Global Settings (Exchange Rates, etc.)
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 5. Notifications Collection
    match /notifications/{notifId} {
      allow read: if isOwner(resource.data.userId) || resource.data.userId == 'admin';
      // Authenticated users can create notifications for themselves or for 'admin'
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid || 
        request.resource.data.userId == 'admin'
      );
      allow update: if isOwner(resource.data.userId);
      allow delete: if isAdmin();
    }

    // 6. Logs Collection (System Activity)
    match /logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn(); // Allow apps to log events
      allow update, delete: if false;
    }

    // Global Deny catch-all
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
